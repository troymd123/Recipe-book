<!-- PWA manifest inline -->
<script>
const manifest = {
  name: "Recipe Registry",
  short_name: "Recipes",
  start_url: ".",
  display: "standalone",
  background_color: "#F7F4EF",
  theme_color: "#F7F4EF",
  icons: [{
    src: "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='22' fill='%23C4501A'/><text y='.9em' font-size='72' x='50%' text-anchor='middle'>🍽</text></svg>",
    sizes: "any", type: "image/svg+xml"
  }]
};
const blob = new Blob([JSON.stringify(manifest)], {type:"application/json"});
const url  = URL.createObjectURL(blob);
const link = document.createElement("link");
link.rel = "manifest"; link.href = url;
document.head.appendChild(link);
</script>

